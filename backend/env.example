# API Configuration
API_TITLE=Conversation Recorder API
API_VERSION=1.0.0
API_DESCRIPTION=Backend API for recording and storing conversation audio files

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200"]

# File Upload Configuration
UPLOADS_DIR=uploads
MAX_FILE_SIZE_MB=50
ALLOWED_AUDIO_TYPES=["audio/webm","audio/mp4","audio/wav","audio/ogg"]

# Security Configuration
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
